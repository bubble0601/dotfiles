"---------------------------------------------------------------------------
" 補完・履歴 Complete
"---------------------------------------------------------------------------
set wildmenu                " コマンド補完を強化
set wildmode=list:full      " リスト表示，最長マッチ
set wildignore+=*/.git/*,*/node_modules/*,*/dist/*,*/build/*
set history=1000            " コマンド・検索パターンの履歴数
set pumheight=10            " 補完を10行までに
