"===========================================================================
" Unite.vim
"===========================================================================
" 入力モードで開始する
let g:unite_enable_start_insert=1
" バッファ一覧
noremap <Space>ub :Unite buffer<CR>
" ファイル一覧
noremap <Space>uf :Unite -buffer-name=file file<CR>
" 最近使ったファイルとバッファ
noremap <Space>uu :Unite file_mru buffer<CR>
" チートシート (モード別: normal / insert / visual)
nnoremap <Space>uc :Unite cheatsheet:normal<CR>
vnoremap <Space>uc :Unite cheatsheet:visual<CR>
inoremap <C-Space>c <ESC>:Unite cheatsheet:insert<CR>
vnoremap <C-Space>c <ESC>:Unite cheatsheet:visual<CR>

" Insert mode から <C-Space> をリーダーとして Unite を開く
inoremap <C-Space>b <ESC>:Unite buffer<CR>
inoremap <C-Space>f <ESC>:Unite -buffer-name=file file<CR>
inoremap <C-Space>u <ESC>:Unite file_mru buffer<CR>

" チートシート Unite ソース
" * はビルトインのキーバインドを示す
let s:cheatsheet_source = {
    \ 'name': 'cheatsheet',
    \ 'description': 'show keybindings cheatsheet',
    \ 'syntax': 'uniteSource__Cheatsheet',
    \ 'hooks': {},
    \ }

function! s:cheatsheet_source.hooks.on_syntax(args, context) abort
    syntax match uniteCheatsheetCategory /\[.*\]/ contained containedin=uniteSource__Cheatsheet
    syntax match uniteCheatsheetBuiltin /\*$/ contained containedin=uniteSource__Cheatsheet
    highlight uniteCheatsheetCategory ctermfg=Yellow guifg=#FFD700
    highlight uniteCheatsheetBuiltin  ctermfg=Cyan   guifg=#88DDFF
endfunction

