function! s:cheatsheet_source.gather_candidates(args, context)
    let mode = get(a:args, 0, 'normal')
    let filtered = filter(copy(s:cheatsheet_items), 'index(v:val.m, mode) >= 0')
    return map(filtered, '{"word": v:val.l, "abbr": v:val.l}')
endfunction

call unite#define_source(s:cheatsheet_source)

"===========================================================================
" lightline
"===========================================================================
let g:lightline = {
  \ 'active': {
  \   'right': [['lineinfo'], ['fileformat', 'fileencoding', 'filetype'], ['indent']]
  \ },
  \ 'component_function': {
  \   'indent': 'LightlineIndent'
  \ }
  \ }

function! LightlineIndent()
  return (&expandtab ? 'spaces' : 'tabs') . ':' . &tabstop
endfunction

